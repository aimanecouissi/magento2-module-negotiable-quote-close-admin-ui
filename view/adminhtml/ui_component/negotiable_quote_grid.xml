<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <listingToolbar name="listing_top">
        <massaction name="listing_massaction">
            <action name="Close">
                <settings>
                    <url path="quotes/quote/massClose"/>
                    <type>close</type>
                    <label translate="true">Close</label>
                    <confirm>
                        <title translate="true">Close Selected Quotes</title>
                        <message translate="true">Are you sure you want to close the selected quotes?</message>
                    </confirm>
                </settings>
            </action>
        </massaction>
    </listingToolbar>
</listing>
