<logging xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Logging:etc/logging.xsd">
    <groups>
        <group name="negotiablequote">
            <events>
                <event controller_action="quotes_quote_close" action_alias="close"/>
                <event controller_action="quotes_quote_massClose" action_alias="massClose"/>
            </events>
        </group>
    </groups>
</logging>
